# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Data folders (keep structure, ignore contents)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Outputs (keep generated artefacts out of git by default)
outputs/*
!outputs/.gitkeep

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
